{
  "id": "spec-review",
  "name": "사양 검토",
  "description": "사양서 초안 작성 → 동료 검토 → 수정 → 최종 승인 → 문서 발행",
  "version": "1.0.0",
  "icon": "📐",
  "contextSchema": {
    "specTitle":   { "type": "string",  "label": "사양서 제목", "required": true },
    "specContent": { "type": "text",    "label": "사양 내용",   "required": true },
    "author":      { "type": "string",  "label": "작성자",      "required": true },
    "reviewer":    { "type": "string",  "label": "검토자" },
    "peerApproved":{ "type": "boolean", "label": "동료 검토 통과" },
    "peerComment": { "type": "text",    "label": "검토 코멘트" },
    "revision":    { "type": "text",    "label": "수정 사항" },
    "finalApproved":{ "type": "boolean","label": "최종 승인" },
    "approverComment":{ "type": "text", "label": "승인자 코멘트" },
    "document":    { "type": "text",    "label": "생성된 문서" }
  },
  "initialState": "draft",
  "states": [
    {
      "id": "draft",
      "label": "초안 작성",
      "module": {
        "type": "form",
        "config": {
          "title": "사양서 초안 작성",
          "fields": [
            { "key": "specTitle",   "label": "사양서 제목", "type": "string", "required": true, "placeholder": "예: 로그인 모듈 사양서 v1" },
            { "key": "author",      "label": "작성자",       "type": "string", "required": true, "placeholder": "홍길동" },
            { "key": "specContent", "label": "사양 내용",    "type": "text",   "required": true, "placeholder": "기능 요구사항, 인터페이스 스펙 등을 기술하세요" }
          ],
          "submitLabel": "동료 검토 요청"
        }
      }
    },
    {
      "id": "peer-review",
      "label": "동료 검토",
      "module": {
        "type": "approval",
        "config": {
          "title": "동료 검토",
          "description": "사양 내용을 검토하고 의견을 남겨주세요.",
          "approveLabel": "검토 통과",
          "rejectLabel": "수정 요청",
          "resultKey": "peerApproved",
          "commentKey": "peerComment"
        }
      }
    },
    {
      "id": "revision",
      "label": "수정",
      "module": {
        "type": "form",
        "config": {
          "title": "사양서 수정",
          "fields": [
            { "key": "specContent", "label": "사양 내용 (수정)", "type": "text", "required": true },
            { "key": "revision",    "label": "수정 내역",         "type": "text", "required": true, "placeholder": "무엇을 어떻게 수정했는지 기술하세요" }
          ],
          "submitLabel": "재검토 요청"
        }
      }
    },
    {
      "id": "final-approval",
      "label": "최종 승인",
      "module": {
        "type": "approval",
        "config": {
          "title": "최종 승인",
          "description": "수정된 사양서를 최종 검토하고 승인해 주세요.",
          "approveLabel": "최종 승인",
          "rejectLabel": "재수정 요청",
          "resultKey": "finalApproved",
          "commentKey": "approverComment"
        }
      }
    },
    {
      "id": "published",
      "label": "발행",
      "terminal": true,
      "module": {
        "type": "document-gen",
        "config": {
          "title": "사양서 발행",
          "outputKey": "document",
          "template": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n사양서: {{specTitle}}\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n작성자: {{author}}\n\n[사양 내용]\n{{specContent}}\n\n[수정 이력]\n{{revision}}\n\n[검토 의견]\n동료 검토: {{peerComment}}\n최종 승인: {{approverComment}}\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n발행 완료"
        }
      }
    }
  ],
  "transitions": [
    {
      "id": "request-peer-review",
      "from": "draft",
      "to": "peer-review",
      "label": "동료 검토 요청",
      "trigger": "manual",
      "condition": null
    },
    {
      "id": "peer-approve",
      "from": "peer-review",
      "to": "final-approval",
      "label": "검토 통과",
      "trigger": "manual",
      "condition": { "==": [{ "var": "peerApproved" }, true] }
    },
    {
      "id": "peer-reject",
      "from": "peer-review",
      "to": "revision",
      "label": "수정 요청",
      "trigger": "manual",
      "condition": null
    },
    {
      "id": "resubmit",
      "from": "revision",
      "to": "peer-review",
      "label": "재검토 요청",
      "trigger": "manual",
      "condition": null
    },
    {
      "id": "final-approve",
      "from": "final-approval",
      "to": "published",
      "label": "최종 승인",
      "trigger": "manual",
      "condition": { "==": [{ "var": "finalApproved" }, true] }
    },
    {
      "id": "final-reject",
      "from": "final-approval",
      "to": "revision",
      "label": "재수정 요청",
      "trigger": "manual",
      "condition": null
    }
  ]
}
