{
  "id": "task-management",
  "name": "과제관리",
  "description": "과제를 생성하고 팀장 승인 후 진행까지 추적합니다.",
  "version": "1.0.0",
  "icon": "📋",
  "contextSchema": {
    "title":    { "type": "string",  "label": "과제 제목",  "required": true },
    "desc":     { "type": "text",    "label": "과제 설명" },
    "assignee": { "type": "string",  "label": "담당자",     "required": true },
    "priority": { "type": "select",  "label": "우선순위",   "options": ["높음", "중간", "낮음"] },
    "approved": { "type": "boolean", "label": "승인 여부" },
    "comment":  { "type": "text",    "label": "검토 코멘트" },
    "progress": { "type": "text",    "label": "진행 내용" }
  },
  "initialState": "create",
  "states": [
    {
      "id": "create",
      "label": "과제 등록",
      "module": {
        "type": "form",
        "config": {
          "title": "과제 등록",
          "fields": [
            { "key": "title",    "label": "과제 제목", "type": "string", "required": true, "placeholder": "과제 제목을 입력하세요" },
            { "key": "desc",     "label": "과제 설명", "type": "text",   "placeholder": "상세 내용을 입력하세요" },
            { "key": "assignee", "label": "담당자",    "type": "string", "required": true, "placeholder": "홍길동" },
            { "key": "priority", "label": "우선순위",  "type": "select", "required": true, "options": ["높음", "중간", "낮음"] }
          ],
          "submitLabel": "검토 요청"
        }
      }
    },
    {
      "id": "review",
      "label": "팀장 검토",
      "module": {
        "type": "approval",
        "config": {
          "title": "팀장 검토",
          "description": "과제 내용을 확인하고 승인 또는 반려해 주세요.",
          "approveLabel": "승인",
          "rejectLabel": "반려",
          "resultKey": "approved",
          "commentKey": "comment"
        }
      }
    },
    {
      "id": "in-progress",
      "label": "진행",
      "module": {
        "type": "form",
        "config": {
          "title": "진행 상황 입력",
          "fields": [
            { "key": "progress", "label": "진행 내용", "type": "text", "required": true, "placeholder": "현재 진행 사항을 입력하세요" }
          ],
          "submitLabel": "완료 처리"
        }
      }
    },
    {
      "id": "done",
      "label": "완료",
      "terminal": true,
      "module": {
        "type": "dashboard",
        "config": {
          "title": "과제 현황판",
          "groupByKey": "status",
          "cardTitleKey": "title",
          "cardSubtitleKey": "assignee",
          "columns": [
            { "value": "create",      "label": "📝 등록" },
            { "value": "review",      "label": "🔍 검토중" },
            { "value": "in-progress", "label": "⚙️ 진행중" },
            { "value": "done",        "label": "✅ 완료" }
          ]
        }
      }
    }
  ],
  "transitions": [
    {
      "id": "submit-for-review",
      "from": "create",
      "to": "review",
      "label": "검토 요청",
      "trigger": "manual",
      "condition": null
    },
    {
      "id": "approve",
      "from": "review",
      "to": "in-progress",
      "label": "승인",
      "trigger": "manual",
      "condition": null
    },
    {
      "id": "reject",
      "from": "review",
      "to": "create",
      "label": "반려",
      "trigger": "manual",
      "condition": null
    },
    {
      "id": "complete",
      "from": "in-progress",
      "to": "done",
      "label": "완료",
      "trigger": "manual",
      "condition": null
    }
  ]
}
